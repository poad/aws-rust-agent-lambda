{
  "name": "aws-rust-agent-lambda",
  "version": "0.1.0",
  "bin": {
    "aws-rust-rag-lambda": "bin/aws-rust-agent-lambda.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc && cd lambda && cargo build",
    "clean": "tsc --build --clean && cd lambda && cargo clean",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "postupdate": "cd lambda && cargo update"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.6.0",
    "@vitest/eslint-plugin": "^1.6.16",
    "aws-cdk": "^2.1119.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-awscdk": "^4.3.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-promise": "^7.2.1",
    "jiti": "^2.6.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.250.0",
    "cargo-lambda-cdk": "^0.0.36",
    "constructs": "^10.6.0"
  },
  "packageManager": "pnpm@10.33.2"
}
